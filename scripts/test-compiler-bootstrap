#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

COMPILER_DIR="$ROOT/compiler"
COMPILER_CLI="$COMPILER_DIR/dist/cli.js"
RUNTIME_JAR="$ROOT/runtime/jvm/kestrel-runtime.jar"
SELFHOST_ENTRY="$ROOT/stdlib/kestrel/tools/compiler/cli-main.ks"
SELFHOST_EXEC_ENTRY="$ROOT/stdlib/kestrel/tools/compiler/cli-entry.ks"
WORK_ROOT="$ROOT/.kestrel/compiler-bootstrap-test"
STAGE0_OUT="$WORK_ROOT/stage0-ts"
PATH1_OUT="$WORK_ROOT/path1"
PATH2_OUT="$WORK_ROOT/path2"

usage() {
  echo "Usage: ./scripts/test-compiler-bootstrap [kestrel-test-args...]" >&2
  echo "Runs a 4-step compiler bootstrap test:" >&2
  echo "  1) TypeScript compiler builds self-hosted compiler classes" >&2
  echo "  2) Compiler from stage0 builds compiler into path1" >&2
  echo "  3) Compiler from path1 builds compiler into path2" >&2
  echo "  4) Compiler from path2 runs unit tests" >&2
}

ensure_tools() {
  command -v node >/dev/null 2>&1 || { echo "test-compiler-bootstrap: node not found" >&2; exit 1; }
  command -v java >/dev/null 2>&1 || { echo "test-compiler-bootstrap: java not found" >&2; exit 1; }
  command -v javac >/dev/null 2>&1 || { echo "test-compiler-bootstrap: javac not found" >&2; exit 1; }
}

main_class_for() {
  local abs_ks rel dir base first rest internal
  abs_ks=$(cd "$(dirname "$1")" && pwd)/$(basename "$1")
  rel="${abs_ks#/}"
  dir=$(dirname "$rel")
  base=$(basename "$rel" .ks)
  base=$(echo "$base" | sed 's/[^a-zA-Z0-9_]/_/g')
  first=$(echo "$base" | cut -c1 | tr 'a-z' 'A-Z')
  rest=$(echo "$base" | cut -c2-)
  if [ "$dir" = "." ]; then
    internal="${first}${rest}"
  else
    internal="$(echo "$dir" | sed 's/[^a-zA-Z0-9_/]/_/g' | tr '/' '.').${first}${rest}"
  fi
  echo "$internal"
}

run_compiler_main() {
  local class_dir="$1"
  shift
  java -cp "$RUNTIME_JAR:$class_dir" "$CLI_MAIN" "$@"
}

main_class_to_file() {
  local main_class="$1"
  echo "$(echo "$main_class" | tr '.' '/').class"
}

require_compiler_class() {
  local class_dir="$1"
  local stage_label="$2"
  local rel
  rel=$(main_class_to_file "$CLI_MAIN")
  if [ ! -f "$class_dir/$rel" ]; then
    local home_candidate="$HOME/.kestrel/jvm/$rel"
    echo "test-compiler-bootstrap: ${stage_label} did not produce self-hosted compiler classes:" >&2
    echo "  expected: $class_dir/$rel" >&2
    if [ -f "$home_candidate" ]; then
      echo "  note: found class in default cache: $home_candidate" >&2
      echo "  this suggests the stage compile path ignored KESTREL_JVM_CACHE (defect to investigate)." >&2
    fi
    echo "TypeScript fallback is disabled by design for this script." >&2
    return 1
  fi
  return 0
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

if [ ! -f "$SELFHOST_ENTRY" ]; then
  echo "test-compiler-bootstrap: missing self-host module entry: $SELFHOST_ENTRY" >&2
  exit 1
fi

if [ ! -f "$SELFHOST_EXEC_ENTRY" ]; then
  echo "test-compiler-bootstrap: missing self-host executable entry: $SELFHOST_EXEC_ENTRY" >&2
  exit 1
fi

ensure_tools

CLI_MAIN=$(main_class_for "$SELFHOST_EXEC_ENTRY")

mkdir -p "$WORK_ROOT"
rm -rf "$STAGE0_OUT" "$PATH1_OUT" "$PATH2_OUT"
mkdir -p "$STAGE0_OUT" "$PATH1_OUT" "$PATH2_OUT"

echo "[bootstrap-test] building TypeScript compiler and JVM runtime"
(cd "$COMPILER_DIR" && npm run build >/dev/null)
(cd "$ROOT/runtime/jvm" && bash build.sh >/dev/null)

echo "[bootstrap-test] 1/4 TypeScript compiler -> stage0 compiler classes"
node "$COMPILER_CLI" "$SELFHOST_EXEC_ENTRY" --target jvm -o "$STAGE0_OUT"

echo "[bootstrap-test] 2/4 stage0 compiler -> path1 compiler classes"
(
  cd "$ROOT"
  export KESTREL_JVM_CACHE="$PATH1_OUT"
  export KESTREL_CLI_TS_FALLBACK=1
  run_compiler_main "$STAGE0_OUT" build "$SELFHOST_EXEC_ENTRY"
)
require_compiler_class "$PATH1_OUT" "step 2"

echo "[bootstrap-test] 3/4 path1 compiler -> path2 compiler classes"
(
  cd "$ROOT"
  export KESTREL_JVM_CACHE="$PATH2_OUT"
  export KESTREL_CLI_TS_FALLBACK=1
  run_compiler_main "$PATH1_OUT" build "$SELFHOST_EXEC_ENTRY"
)
require_compiler_class "$PATH2_OUT" "step 3"

echo "[bootstrap-test] 4/4 run unit tests via path2 compiler"
(
  cd "$ROOT"
  # Point the wrapper at path2 as its active self-hosted compiler cache.
  KESTREL_JVM_CACHE="$PATH2_OUT" "$ROOT/kestrel" test "$@"
)

echo "[bootstrap-test] PASS"
echo "  stage0 classes: $STAGE0_OUT"
echo "  path1 classes : $PATH1_OUT"
echo "  path2 classes : $PATH2_OUT"
