#!/usr/bin/env bash
# Kestrel CLI shim — delegates to the self-hosted Kestrel CLI after bootstrap.
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"; SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"; export KESTREL_ROOT="$ROOT"
COMPILER="$ROOT/compiler"; COMPILER_CLI="$COMPILER/dist/cli.js"
JVM_CACHE="${KESTREL_JVM_CACHE:-$HOME/.kestrel/jvm}"
MAVEN="${KESTREL_MAVEN_CACHE:-$HOME/.kestrel/maven}"
MAVEN_RUNTIME_JAR="$MAVEN/lang/kestrel/runtime/1.0/runtime-1.0.jar"
MAVEN_BOOTSTRAP_JAR="$MAVEN/lang/kestrel/compile/1.0/compile-1.0.jar"

# --allow-ts-compiler __ts-compile: direct TypeScript compiler invocation (bootstrap only)
if [ "${1:-}" = "--allow-ts-compiler" ] && [ "${2:-}" = "__ts-compile" ]; then
  shift 2; exec node "$COMPILER_CLI" "$1" --target jvm -o "$2" "${@:3}"
fi

# bootstrap: extract bootstrap JAR to JVM cache
if [ "${1:-}" = "bootstrap" ]; then
  [ -f "$MAVEN_RUNTIME_JAR" ] || { echo "kestrel bootstrap: missing runtime jar; run ./kestrel build" >&2; exit 1; }
  [ -f "$MAVEN_BOOTSTRAP_JAR" ] || { echo "kestrel bootstrap: missing bootstrap JAR; run ./scripts/build-bootstrap-jar.sh" >&2; exit 1; }
  mkdir -p "$JVM_CACHE" && (cd "$JVM_CACHE" && jar xf "$MAVEN_BOOTSTRAP_JAR")
  find "$JVM_CACHE" -name "Cli_entry.class" -print -quit | grep -q . || { echo "kestrel bootstrap: Cli_entry.class missing after extraction" >&2; exit 1; }
  find "$JVM_CACHE" -name "Cli_main.class" -print -quit | grep -q . || { echo "kestrel bootstrap: Cli_main.class missing after extraction" >&2; exit 1; }
  echo "kestrel bootstrap: self-hosted compiler classes installed successfully"; exit 0
fi

# build (no args): rebuild TypeScript compiler and JVM runtime from source
if [ "${1:-}" = "build" ] && [ -z "${2:-}" ]; then
  command -v node >/dev/null || { echo "kestrel: node not found" >&2; exit 1; }
  command -v javac >/dev/null || { echo "kestrel: javac not found" >&2; exit 1; }
  (cd "$COMPILER" && npm run build >/dev/null 2>&1) || { echo "kestrel: compiler build failed" >&2; exit 1; }
  (cd "$ROOT/runtime/jvm" && bash build.sh >/dev/null 2>&1) || { echo "kestrel: JVM runtime build failed" >&2; exit 1; }
  mkdir -p "$(dirname "$MAVEN_RUNTIME_JAR")" && cp "$ROOT/runtime/jvm/kestrel-runtime.jar" "$MAVEN_RUNTIME_JAR"; exit 0
fi

# All other commands: delegate to the self-hosted Kestrel CLI
CLI_CLASS=$(find "$JVM_CACHE" -name "Cli.class" -path "*/kestrel/tools/Cli.class" 2>/dev/null \
  | head -1 | sed "s|$JVM_CACHE/||;s|\.class\$||" | tr '/' '.') || CLI_CLASS=""
[ -n "$CLI_CLASS" ] || { echo "kestrel: self-hosted compiler artifacts are required for this command" >&2; echo "  run: ./scripts/build-bootstrap-jar.sh && ./kestrel bootstrap" >&2; exit 1; }
exec java -Xss8m -Dkestrel.exitWait=false -cp "$MAVEN_RUNTIME_JAR:$JVM_CACHE" "$CLI_CLASS" "$@"
