#!/usr/bin/env bash
# Kestrel CLI: kestrel <command> [options]
# Commands: run, dis, build, bootstrap, test, fmt, doc, lock
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
COMPILER="$ROOT/compiler"
COMPILER_CLI="$COMPILER/dist/cli.js"
# Cache root: .class files under ~/.kestrel/jvm (clean: rm -rf ~/.kestrel)
JVM_CACHE="${KESTREL_JVM_CACHE:-$HOME/.kestrel/jvm}"
RUNTIME_JAR="$ROOT/runtime/jvm/kestrel-runtime.jar"
MAVEN_CLASSPATH_RESOLVER="$ROOT/scripts/resolve-maven-classpath.mjs"
BOOTSTRAP_ROOT="$ROOT/.kestrel/bootstrap"
BOOTSTRAP_COMPILER_DIR="$BOOTSTRAP_ROOT/compiler"
BOOTSTRAP_JAR="$BOOTSTRAP_COMPILER_DIR/compiler-bootstrap.jar"
BOOTSTRAP_SELFHOST_DIR="$BOOTSTRAP_ROOT/self-hosted"
BOOTSTRAP_ENTRY="$ROOT/stdlib/kestrel/tools/compiler/cli-entry.ks"

usage() {
  echo "Usage: kestrel <command> [options]" >&2
  echo "  run   [--exit-wait|--exit-no-wait] <script[.ks]> [args...]  Compile if needed, then execute on JVM" >&2
  echo "  dis   [--verbose|--code-only] <script[.ks]>  Compile if needed, then disassemble JVM bytecode" >&2
  echo "  build [script.ks]  Build compiler and JVM runtime; optionally compile script" >&2
  echo "  bootstrap  Build self-hosted compiler classes from bootstrap compiler JAR" >&2
  echo "  test  [--verbose|--summary] [--clean] [--refresh] [--allow-http] [files...]   Run unit tests on JVM (default: compact output)" >&2
  echo "  fmt   [--check] [--stdin] [files-or-dirs...]  Format Kestrel source files (default: all .ks files in current dir)" >&2
  echo "  doc   [--port PORT] [--project-root PATH]       Start the documentation browser (default port: 7070)" >&2
  echo "  lock  <lockfile>  Update URL lockfile (self-hosted CLI scaffold)" >&2
  exit 1
}

run_usage() {
  echo "Usage: kestrel run [--exit-wait|--exit-no-wait] [--refresh] [--allow-http] [--clean] <script[.ks]> [args...]"
  echo "  --exit-wait     Wait for pending async work before process exit (default)."
  echo "  --exit-no-wait  Exit when main returns and abandon pending async work."
  echo "  --clean         Delete all .kti incremental-cache files before compilation."
}

ensure_tools() {
  if ! command -v node &>/dev/null; then
    echo "kestrel: node not found" >&2
    exit 1
  fi
  if ! command -v java &>/dev/null; then
    echo "kestrel: java not found" >&2
    exit 1
  fi
  if ! command -v javac &>/dev/null; then
    echo "kestrel: javac not found" >&2
    exit 1
  fi
}

build_compiler_jvm() {
  cd "$COMPILER" && npm run build >/dev/null 2>&1 && cd "$ROOT" || {
    echo "kestrel: compiler build failed" >&2
    exit 1
  }
  (cd "$ROOT/runtime/jvm" && ./build.sh >/dev/null 2>&1) || {
    cd "$ROOT"
    echo "kestrel: JVM runtime build failed" >&2
    exit 1
  }
}

# Return 0 (true) if the compiler or runtime needs to be (re)built.
# Triggers when dist/cli.js or the runtime jar is missing, when any
# TypeScript source file is newer than the compiled output, or when any
# Java source file (or build.sh) is newer than the runtime jar.
compiler_build_needed() {
  [ ! -f "$COMPILER_CLI" ] && return 0
  [ ! -f "$RUNTIME_JAR" ] && return 0
  find "$COMPILER/src" -name "*.ts" -newer "$COMPILER_CLI" -print -quit 2>/dev/null | grep -q . && return 0
  [ "$COMPILER/cli.ts" -nt "$COMPILER_CLI" ] && return 0
  find "$ROOT/runtime/jvm/src" -name "*.java" -newer "$RUNTIME_JAR" -print -quit 2>/dev/null | grep -q . && return 0
  [ "$ROOT/runtime/jvm/build.sh" -nt "$RUNTIME_JAR" ] && return 0
  return 1
}

resolve_script() {
  local arg="$1"
  if [ -f "$arg" ]; then
    echo "$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")"
    return
  fi
  if [[ "$arg" == *.ks ]]; then
    echo "" && return
  fi
  if [ -f "${arg}.ks" ]; then
    echo "$(cd "$(dirname "${arg}.ks")" && pwd)/$(basename "${arg}.ks")"
    return
  fi
  echo ""
}

# Resolve a kestrel: module specifier to an absolute .ks path (or empty string on failure).
# Example: kestrel:dev/test -> $ROOT/stdlib/kestrel/dev/test.ks
resolve_module_specifier() {
  local spec="$1"
  local rest="${spec#kestrel:}"
  local candidate="$ROOT/stdlib/kestrel/${rest}.ks"
  if [ -f "$candidate" ]; then
    echo "$candidate"
  else
    echo ""
  fi
}

# Given absolute path to .ks, return directory for JVM .class files
jvm_class_dir_for() {
  local ks="$1"
  # With stable JVM class naming, all classes live under the JVM cache root.
  echo "${JVM_CACHE}"
}

# Java main class name from script path (e.g. mandelbrot.ks -> Mandelbrot)
# Uses the same naming scheme as `classNameForPath` in the JVM compiler.
# Each path segment is sanitized: characters that are not letters, digits, or
# underscores are replaced with '_' so the result is a valid Java identifier.
main_class_for() {
  local base first rest
  local abs_ks
  local rel
  local dir
  abs_ks=$(cd "$(dirname "$1")" && pwd)/$(basename "$1")
  rel="${abs_ks#/}"
  dir=$(dirname "$rel")
  base=$(basename "$rel" .ks)
  base=$(echo "$base" | sed 's/[^a-zA-Z0-9_]/_/g')
  first=$(echo "$base" | cut -c1 | tr 'a-z' 'A-Z')
  rest=$(echo "$base" | cut -c2-)
  if [ "$dir" = "." ]; then
    echo "${first}${rest}"
  else
    echo "$(echo "$dir" | sed 's/[^a-zA-Z0-9_/]/_/g' | tr '/' '.').$first$rest"
  fi
}

is_integer() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

file_mtime() {
  local path="$1"
  local out=""

  # GNU coreutils (Linux)
  out=$(stat -c '%Y' "$path" 2>/dev/null || true)
  if is_integer "$out"; then
    echo "$out"
    return 0
  fi

  # BSD/macOS
  out=$(stat -f '%m' "$path" 2>/dev/null || true)
  if is_integer "$out"; then
    echo "$out"
    return 0
  fi

  echo ""
  return 1
}

needs_compile_jvm() {
  local ks="$1" class_dir="$2"
  local abs_ks rel dir base first rest internal_last internal_name class_file deps
  abs_ks=$(cd "$(dirname "$ks")" && pwd)/$(basename "$ks")
  rel="${abs_ks#/}"
  dir=$(dirname "$rel")
  base=$(basename "$rel" .ks)
  base=$(echo "$base" | sed 's/[^a-zA-Z0-9_]/_/g')
  first=$(echo "$base" | cut -c1 | tr 'a-z' 'A-Z')
  rest=$(echo "$base" | cut -c2-)
  internal_last="${first}${rest}"
  if [ "$dir" = "." ]; then
    internal_name="$internal_last"
  else
    internal_name="$(echo "$dir" | sed 's/[^a-zA-Z0-9_/]/_/g')/${internal_last}"
  fi
  class_file="${class_dir}/${internal_name}.class"
  [ ! -f "$class_file" ] && return 0
  deps="${class_file}.deps"
  if [ -f "$deps" ]; then
    while IFS= read -r dep || [ -n "$dep" ]; do
      dep="${dep%$'\r'}"
      dep="${dep#"${dep%%[![:space:]]*}"}"
      dep="${dep%"${dep##*[![:space:]]}"}"
      [ -z "$dep" ] && continue
      if [ -f "$dep" ]; then
        dep_mtime=$(file_mtime "$dep")
        class_mtime=$(file_mtime "$class_file")
        [ -n "$dep_mtime" ] && [ -n "$class_mtime" ] && [ "$dep_mtime" -ge "$class_mtime" ] && return 0
      fi
    done < "$deps"
    return 1
  fi
  [ "$ks" -nt "$class_file" ] 2>/dev/null && return 0
  return 1
}

maven_classpath_for_entry() {
  local entry_source="$1"
  local class_dir="$2"
  if [ ! -f "$MAVEN_CLASSPATH_RESOLVER" ]; then
    echo ""
    return 0
  fi
  node "$MAVEN_CLASSPATH_RESOLVER" "$entry_source" "$class_dir"
}

cmd_build() {
  ensure_tools
  build_compiler_jvm
  if [ -n "${1:-}" ]; then
    local resolved class_dir
    local refresh_flag="" allow_http_flag="" status_flag="" clean_flag=""
    # Parse optional flags before the script path
    while [ $# -gt 0 ]; do
      case "${1:-}" in
        --refresh) refresh_flag="--refresh"; shift ;;
        --allow-http) allow_http_flag="--allow-http"; shift ;;
        --status) status_flag="--status"; shift ;;
        --clean) clean_flag="--clean"; shift ;;
        *) break ;;
      esac
    done
    if [ -z "${1:-}" ]; then
      echo "kestrel build: script path required after flags" >&2
      exit 1
    fi
    resolved=$(resolve_script "$1")
    if [ -z "$resolved" ]; then
      echo "kestrel: script not found: $1" >&2
      exit 1
    fi
    class_dir=$(jvm_class_dir_for "$resolved")
    mkdir -p "$class_dir"
    # shellcheck disable=SC2086
    if ! (cd "$ROOT" && node "$COMPILER_CLI" "$resolved" --target jvm -o "$class_dir" $refresh_flag $allow_http_flag $status_flag $clean_flag); then
      echo "kestrel: JVM compile failed" >&2
      exit 1
    fi
    if [ -z "$status_flag" ]; then
      echo "Built $class_dir (JVM)"
    fi
  fi
}

cmd_run() {
  local exit_mode="" refresh_flag="" allow_http_flag="" clean_flag=""
  while [ $# -gt 0 ]; do
    case "${1:-}" in
      --help|-h)
        run_usage
        exit 0
        ;;
      --exit-wait)
        if [ "$exit_mode" = "no-wait" ]; then
          echo "kestrel: --exit-wait and --exit-no-wait are mutually exclusive" >&2
          exit 1
        fi
        exit_mode="wait"
        shift
        ;;
      --exit-no-wait)
        if [ "$exit_mode" = "wait" ]; then
          echo "kestrel: --exit-wait and --exit-no-wait are mutually exclusive" >&2
          exit 1
        fi
        exit_mode="no-wait"
        shift
        ;;
      --refresh)
        refresh_flag="--refresh"
        shift
        ;;
      --allow-http)
        allow_http_flag="--allow-http"
        shift
        ;;
      --clean)
        clean_flag="--clean"
        shift
        ;;
      *)
        break
        ;;
    esac
  done
  if [ -z "${1:-}" ]; then
    usage
  fi
  ensure_tools
  if compiler_build_needed; then
    build_compiler_jvm
  fi
  local resolved class_dir main_class
  # Support kestrel: module specifiers (e.g. kestrel:tools/test)
  if [[ "${1:-}" == kestrel:* ]]; then
    local spec="$1"
    resolved=$(resolve_module_specifier "$spec")
    if [ -z "$resolved" ]; then
      echo "kestrel: stdlib module not found: $spec" >&2
      exit 1
    fi
  else
    resolved=$(resolve_script "$1")
    if [ -z "$resolved" ]; then
      echo "kestrel: script not found: $1" >&2
      exit 1
    fi
  fi
  shift
  class_dir=$(jvm_class_dir_for "$resolved")
  if [ -n "$clean_flag" ] || needs_compile_jvm "$resolved" "$class_dir"; then
    mkdir -p "$class_dir"
    # shellcheck disable=SC2086
    if ! (cd "$ROOT" && node "$COMPILER_CLI" "$resolved" --target jvm -o "$class_dir" $refresh_flag $allow_http_flag $clean_flag); then
      echo "kestrel: JVM compile failed for $resolved" >&2
      exit 1
    fi
  fi
  main_class=$(main_class_for "$resolved")
  local maven_cp=""
  maven_cp=$(maven_classpath_for_entry "$resolved" "$class_dir")
  local java_cp="$RUNTIME_JAR:$class_dir"
  if [ -n "$maven_cp" ]; then
    java_cp="$java_cp:$maven_cp"
  fi
  if [ "$exit_mode" = "no-wait" ]; then
    exec java -Xss8m -Dkestrel.exitWait=false -cp "$java_cp" "$main_class" "$@"
  else
    exec java -Xss8m -cp "$java_cp" "$main_class" "$@"
  fi
}

cmd_dis() {
  local verbose=false
  local code_only=false
  local script=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --verbose) verbose=true ;;
      --code-only) code_only=true ;;
      -*) echo "kestrel: unknown dis flag: $1" >&2; usage ;;
      *) script="$1" ;;
    esac
    shift
  done

  if [ -z "$script" ]; then
    usage
  fi
  if ! command -v javap &>/dev/null; then
    echo "kestrel: javap not found" >&2
    exit 1
  fi
  if compiler_build_needed; then
    build_compiler_jvm
  fi
  local resolved
  resolved=$(resolve_script "$script")
  if [ -z "$resolved" ]; then
    echo "kestrel: script not found: $script" >&2
    exit 1
  fi
  local class_dir main_class
  class_dir=$(jvm_class_dir_for "$resolved")
  if needs_compile_jvm "$resolved" "$class_dir"; then
    mkdir -p "$class_dir"
    if ! (cd "$ROOT" && node "$COMPILER_CLI" "$resolved" --target jvm -o "$class_dir"); then
      echo "kestrel: JVM compile failed for $resolved" >&2
      exit 1
    fi
  fi
  main_class=$(main_class_for "$resolved")

  local args=("-classpath" "$RUNTIME_JAR:$class_dir")
  if $verbose; then
    args+=("-verbose")
  fi
  args+=("-c")
  if ! $code_only; then
    args+=("-l")
  fi
  args+=("$main_class")
  exec javap "${args[@]}"
}

cmd_test() {
  ensure_tools
  if compiler_build_needed; then
    build_compiler_jvm
  fi
  KESTREL_BIN="$ROOT/kestrel" exec "$ROOT/kestrel" run "kestrel:tools/test" "$@"
}

cmd_bootstrap() {
  ensure_tools
  local bootstrap_main_class
  bootstrap_main_class=$(main_class_for "$BOOTSTRAP_ENTRY")

  if [ ! -f "$RUNTIME_JAR" ]; then
    echo "kestrel bootstrap: missing runtime jar: $RUNTIME_JAR" >&2
    echo "kestrel bootstrap: run ./kestrel build to generate runtime artifacts" >&2
    exit 1
  fi

  if [ ! -f "$BOOTSTRAP_JAR" ]; then
    echo "kestrel bootstrap: missing bootstrap compiler jar: $BOOTSTRAP_JAR" >&2
    echo "kestrel bootstrap: run ./scripts/build-bootstrap-jar.sh first" >&2
    exit 1
  fi

  rm -rf "$BOOTSTRAP_SELFHOST_DIR"
  mkdir -p "$BOOTSTRAP_SELFHOST_DIR"

  if ! env KESTREL_JVM_CACHE="$BOOTSTRAP_SELFHOST_DIR" java -Xss8m -cp "$RUNTIME_JAR:$BOOTSTRAP_JAR" "$bootstrap_main_class" build "$BOOTSTRAP_ENTRY"; then
    echo "kestrel bootstrap: bootstrap compile failed while generating self-hosted compiler classes" >&2
    echo "kestrel bootstrap: attempted entry class: $bootstrap_main_class" >&2
    exit 1
  fi

  if ! find "$BOOTSTRAP_SELFHOST_DIR" -name "Cli_entry.class" -print -quit | grep -q .; then
    echo "kestrel bootstrap: missing Cli_entry.class in $BOOTSTRAP_SELFHOST_DIR" >&2
    exit 1
  fi
  if ! find "$BOOTSTRAP_SELFHOST_DIR" -name "Cli_main.class" -print -quit | grep -q .; then
    echo "kestrel bootstrap: missing Cli_main.class in $BOOTSTRAP_SELFHOST_DIR" >&2
    exit 1
  fi

  echo "kestrel bootstrap: wrote self-hosted compiler classes"
  echo "  bootstrap jar : $BOOTSTRAP_JAR"
  echo "  output classes: $BOOTSTRAP_SELFHOST_DIR"
}

cmd_fmt() {
  ensure_tools
  if [ ! -f "$COMPILER_CLI" ] || [ ! -f "$RUNTIME_JAR" ]; then
    build_compiler_jvm
  fi
  local fmt_script="$ROOT/stdlib/kestrel/tools/format.ks"
  exec "$ROOT/kestrel" run "$fmt_script" "$@"
}

cmd_doc() {
  ensure_tools
  if [ ! -f "$COMPILER_CLI" ] || [ ! -f "$RUNTIME_JAR" ]; then
    build_compiler_jvm
  fi
  local doc_script="$ROOT/stdlib/kestrel/tools/doc.ks"
  exec "$ROOT/kestrel" run "$doc_script" "$@"
}

cmd_lock() {
  echo "kestrel lock: delegated to self-hosted CLI scaffold when available" >&2
  exit 0
}

selfhost_cli_available() {
  [ -f "$ROOT/stdlib/kestrel/tools/compiler/cli-entry.ks" ]
}

maybe_exec_selfhost_cli() {
  [ "${KESTREL_CLI_TS_FALLBACK:-0}" = "1" ] && return 0
  case "${1:-}" in
    run|dis|build|test|fmt|doc|lock)
      if selfhost_cli_available; then
        exec env KESTREL_CLI_TS_FALLBACK=1 "$ROOT/kestrel" run "kestrel:tools/compiler/cli-entry" "$@"
      fi
      ;;
  esac
}

# Main
maybe_exec_selfhost_cli "$@"
case "${1:-}" in
  run)   shift; cmd_run "$@" ;;
  dis)   shift; cmd_dis "$@" ;;
  build) shift; cmd_build "$@" ;;
  bootstrap) shift; cmd_bootstrap "$@" ;;
  test)       shift; cmd_test "$@" ;;
  fmt)   shift; cmd_fmt "$@" ;;
  doc)   shift; cmd_doc "$@" ;;
  lock)  shift; cmd_lock "$@" ;;
  # Implicit run: when first arg is a .ks file (enables shebang #!/usr/bin/env kestrel)
  *.ks)  cmd_run "$@" ;;
  *)     usage ;;
esac
