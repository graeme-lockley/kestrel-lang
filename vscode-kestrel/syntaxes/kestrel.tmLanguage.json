{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kestrel",
  "scopeName": "source.kestrel",
  "patterns": [
    { "include": "#doc-comments" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "doc-comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.kestrel",
          "match": "^(\\s*)(///|//!).*$"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.kestrel",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.kestrel",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kestrel",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kestrel",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.kestrel",
              "begin": "\\\\\\${",
              "end": "}",
              "patterns": [
                { "include": "#keywords" },
                { "include": "#numbers" },
                { "include": "#types" },
                { "include": "#identifiers" }
              ]
            }
          ]
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.kestrel",
          "match": "'(?:\\\\.|[^'\\\\])'"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kestrel",
          "match": "\\b(as|fun|type|val|var|mut|if|else|while|break|continue|match|try|catch|throw|async|await|export|import|from|exception|is|opaque|extern)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.kestrel",
          "match": "\\b(True|False)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.kestrel",
          "match": "\\b\\d+(?:_\\d+)*(?:\\.\\d+(?:_\\d+)*)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.kestrel",
          "match": "\\|>|::|->|=>|:=|==|!=|<=|>=|&&|\\|\\||[+\\-*/%<>=|&]"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.kestrel",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.kestrel",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
