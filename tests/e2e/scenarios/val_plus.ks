// Test basic arithmetic operations
val add = 10 + 5
val sub = 10 - 3
val mul = 6 * 7
val div = 20 / 4
val mod = 17 % 5

println(add)
// 15
println(sub)
// 7
println(mul)
// 42
println(div)
// 5
println(mod)
// 2

// Test operator precedence
val complex = 2 + 3 * 4
val parens = (2 + 3) * 4

println(complex)
// 14
println(parens)
// 20

// Test chained operations
val chain1 = 100 / 10 / 2
val chain2 = 10 - 3 - 2

println(chain1)
// 5
println(chain2)
// 5
