// Test basic arithmetic operations
val add = 10 + 5
val sub = 10 - 3
val mul = 6 * 7
val div = 20 / 4
val mod = 17 % 5

print(add)
print(sub)
print(mul)
print(div)
print(mod)

// Test operator precedence
val complex = 2 + 3 * 4
val parens = (2 + 3) * 4

print(complex)
print(parens)

// Test chained operations
val chain1 = 100 / 10 / 2
val chain2 = 10 - 3 - 2

print(chain1)
print(chain2)
