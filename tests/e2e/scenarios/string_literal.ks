// Test string literals and printing
val greeting = "Hello, World!"
val message = "Kestrel strings work!"
val empty = ""
val withSpaces = "  spaces  "

print(greeting)
// Hello, World!
print(message)
// Kestrel strings work!
print(empty)
//
print(withSpaces)
//   spaces  

// Test strings with special characters
val newline = "Line1\nLine2"
val tab = "Tab\there"
val quote = "She said \"hello\""

print(newline)
// Line1
// Line2
print(tab)
// Tab	here
print(quote)
// She said "hello"
